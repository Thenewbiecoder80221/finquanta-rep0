generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model TelemetryEvent {
  id         Int      @id @default(autoincrement())

  sessionId  String
  userId     String

  eventType  String
  value      Float

  trustScore Int
  riskScore  Int
  riskLevel  String

  transactionAmount Float?
  transactionType   String?
  newBeneficiary    Boolean?

  createdAt DateTime @default(now())
}